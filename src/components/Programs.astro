---
import { ArrowRight, Check, Clock, Dumbbell, Target, Trophy } from 'lucide-astro';
import { filters, programs, whatsappPhone } from '@/data/site';

const getWhatsAppHref = (planTitle: string) =>
  `https://wa.me/${whatsappPhone}?text=${encodeURIComponent(`Hola! Estoy interesado en adquirir el plan ${planTitle}`)}`;
---

<section id="programas" class="programs-section">
  <div class="container-page">
    <div class="section-heading reveal" data-reveal>
      <p class="section-kicker">Programas</p>
      <h2 class="display-title">Elegí tu plan</h2>
      <p>Tres caminos claros para entrenar con estructura según tu objetivo principal.</p>
    </div>

    <div id="selector-programas" class="filter-row reveal" data-reveal role="toolbar" aria-label="Filtrar programas">
      {filters.map((filter, index) => (
        <button
          class:list={['filter-button', { 'is-active': index === 0 }]}
          type="button"
          data-filter={filter.id}
          aria-pressed={index === 0 ? 'true' : 'false'}
        >
          {filter.label}
        </button>
      ))}
    </div>

    <div class="program-test-prompt reveal" data-reveal>
      <span>¿No sabés cuál elegir?</span>
      <a href="#encontra-tu-plan" data-open-quiz>Hacé el test</a>
    </div>

    <div class="program-grid" data-program-grid>
      {programs.map((program) => (
        <article
          class:list={['program-card reveal', { 'is-featured': program.featured }]}
          data-reveal
          data-program-card
          data-category={program.category}
        >
          <picture class="program-image">
            <source srcset={program.image.avif} type="image/avif" />
            <source srcset={program.image.webp} type="image/webp" />
            <img src={program.image.webp} alt="" width="720" height="920" loading="lazy" decoding="async" />
          </picture>

          <div class="program-shade" aria-hidden="true"></div>

          <div class="program-top">
            <span>{program.categoryLabel}</span>
            {program.badge && <strong>{program.badge}</strong>}
          </div>

          <div class="program-content">
            <h3>{program.title}</h3>
            <p class="program-description">{program.description}</p>
            <p class="program-audience"><span></span>{program.audience}</p>
            <button class="program-buy" type="button" data-open-dialog={`program-${program.slug}`}>
              Comprar plan
              <ArrowRight size={16} stroke-width={2} aria-hidden="true" />
            </button>
          </div>
        </article>
      ))}
    </div>
  </div>

  {programs.map((program) => (
    <dialog class="program-dialog" id={`program-${program.slug}`} data-program-dialog>
      <div class="dialog-shell">
        <div class="dialog-media">
          <picture>
            <source srcset={program.image.avif} type="image/avif" />
            <source srcset={program.image.webp} type="image/webp" />
            <img src={program.image.webp} alt="" width="720" height="920" loading="lazy" decoding="async" />
          </picture>
          {program.badge && <span class="dialog-badge">{program.badge}</span>}
        </div>

        <div class="dialog-content">
          <button class="dialog-close" type="button" value="cancel" data-close-dialog aria-label="Cerrar">×</button>
          <p class="section-kicker">{program.categoryLabel}</p>
          <h3 class="display-title">{program.title}</h3>
          <p class="dialog-lead">{program.description}</p>

          <div class="program-meta">
            <div>
              <Clock size={18} stroke-width={1.8} aria-hidden="true" />
              <span>Duración</span>
              <strong>{program.duration}</strong>
            </div>
            <div>
              <Trophy size={18} stroke-width={1.8} aria-hidden="true" />
              <span>Nivel</span>
              <strong>{program.level}</strong>
            </div>
            <div>
              <Target size={18} stroke-width={1.8} aria-hidden="true" />
              <span>Objetivo</span>
              <strong>{program.goal}</strong>
            </div>
            <div>
              <Dumbbell size={18} stroke-width={1.8} aria-hidden="true" />
              <span>Requisitos</span>
              <strong>{program.requirements}</strong>
            </div>
          </div>

          <div class="dialog-columns">
            <section>
              <h4>Qué incluye</h4>
              <ul>
                {program.includes.map((item) => (
                  <li><Check size={17} stroke-width={2} aria-hidden="true" />{item}</li>
                ))}
              </ul>
            </section>
            <section>
              <h4>Entrega y precio</h4>
              <p>{program.delivery}</p>
              <p><strong>{program.price}</strong>. Coordinación final por WhatsApp.</p>
            </section>
          </div>

          <div class="dialog-faq">
            {program.faq.map((item) => (
              <details>
                <summary>{item.question}</summary>
                <p>{item.answer}</p>
              </details>
            ))}
          </div>

          <div class="dialog-actions">
            <a
              class="btn btn-primary"
              href={getWhatsAppHref(program.title)}
              target="_blank"
              rel="noreferrer"
            >
              Comprar ahora
              <ArrowRight size={17} stroke-width={2} aria-hidden="true" />
            </a>
            <button class="btn btn-secondary-light" type="button" data-close-dialog>Cerrar</button>
          </div>
        </div>
      </div>
    </dialog>
  ))}
</section>

<style>
  .programs-section {
    background: #f1efe6;
    color: #11130f;
    padding: 112px 0 118px;
  }

  .section-heading {
    width: min(100%, 650px);
    margin-inline: auto;
    text-align: center;
  }

  .section-heading .section-kicker {
    justify-content: center;
  }

  .section-heading .section-kicker::after {
    content: '';
    width: 24px;
    height: 1px;
    background: currentColor;
  }

  .section-heading h2 {
    margin: 14px 0 0;
    font-size: clamp(4rem, 8vw, 6.6rem);
    text-transform: uppercase;
  }

  .section-heading p:last-child {
    margin: 18px auto 0;
    width: min(100%, 520px);
    color: #6d726c;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .filter-row {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin: 46px auto 18px;
    overflow-x: auto;
    padding: 4px 0 12px;
    scroll-margin-top: 124px;
    scrollbar-width: none;
  }

  .program-test-prompt {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin: 0 0 48px;
    color: #62675f;
    font-size: 0.94rem;
    font-weight: 700;
  }

  .program-test-prompt a {
    color: #8a7a2f;
    font-weight: 900;
    text-decoration: underline;
    text-decoration-color: rgba(138, 122, 47, 0.28);
    text-underline-offset: 4px;
    transition: color 180ms ease, text-decoration-color 180ms ease;
  }

  .program-test-prompt a:hover {
    color: #5f5525;
    text-decoration-color: currentColor;
  }

  .filter-row::-webkit-scrollbar {
    display: none;
  }

  .filter-button {
    flex: 0 0 auto;
    min-width: 104px;
    border: 1px solid transparent;
    border-radius: 4px;
    padding: 15px 20px 14px;
    background: transparent;
    color: #6f736d;
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: 1.06rem;
    letter-spacing: 0.11em;
    line-height: 1;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease,
      color 180ms ease;
  }

  .filter-button:hover {
    color: #11130f;
    transform: translateY(-2px);
  }

  .filter-button.is-active {
    background: #070807;
    color: #fff;
    box-shadow: 0 14px 36px rgba(0, 0, 0, 0.18);
  }

  .program-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 32px;
  }

  .program-card {
    position: relative;
    display: grid;
    min-height: 472px;
    overflow: hidden;
    border: 1px solid rgba(17, 19, 15, 0.12);
    border-radius: 6px;
    background: #070807;
    color: #fff;
    box-shadow: 0 18px 42px rgba(17, 19, 15, 0.08);
    transition:
      opacity 260ms ease,
      transform 220ms ease,
      border-color 220ms ease,
      box-shadow 220ms ease;
  }

  .program-card.is-hidden {
    display: none;
  }

  .program-card.is-featured {
    border-color: rgba(138, 122, 47, 0.9);
    box-shadow: 0 24px 56px rgba(138, 122, 47, 0.2);
  }

  .program-card:hover {
    transform: translateY(-6px);
    border-color: rgba(138, 122, 47, 0.9);
    box-shadow: 0 28px 72px rgba(17, 19, 15, 0.18);
  }

  .program-image,
  .program-image img,
  .program-shade {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .program-image img {
    object-fit: cover;
    opacity: 0.82;
    transition:
      transform 500ms ease,
      opacity 500ms ease;
  }

  .program-card:hover .program-image img {
    transform: scale(1.055);
    opacity: 0.92;
  }

  .program-shade {
    background:
      linear-gradient(180deg, rgba(7, 8, 7, 0.36) 0%, rgba(7, 8, 7, 0.42) 38%, rgba(7, 8, 7, 0.96) 100%),
      radial-gradient(circle at center, rgba(7, 8, 7, 0) 0%, rgba(7, 8, 7, 0.58) 100%);
  }

  .program-top {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    padding: 26px 26px 0;
  }

  .program-top span,
  .program-top strong {
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    line-height: 1;
    text-transform: uppercase;
  }

  .program-top span {
    color: rgba(255, 255, 255, 0.72);
  }

  .program-top strong {
    border-radius: 999px;
    padding: 7px 9px;
    background: #8a7a2f;
    color: #fff;
  }

  .program-content {
    position: relative;
    z-index: 1;
    align-self: end;
    padding: 0 26px 26px;
  }

  .program-content h3 {
    margin: 0;
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: clamp(2rem, 3.2vw, 2.55rem);
    letter-spacing: 0.04em;
    line-height: 0.96;
    text-transform: uppercase;
  }

  .program-description {
    margin: 18px 0 0;
    color: rgba(255, 255, 255, 0.76);
    font-size: 0.96rem;
    line-height: 1.55;
  }

  .program-audience {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    min-height: 38px;
    margin: 14px 0 20px;
    color: rgba(255, 255, 255, 0.58);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .program-audience span {
    flex: 0 0 auto;
    width: 18px;
    height: 1px;
    margin-top: 9px;
    background: #a69645;
  }

  .program-buy {
    display: flex;
    width: 100%;
    min-height: 42px;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border: 1px solid rgba(138, 122, 47, 0.9);
    border-radius: 3px;
    background: #8a7a2f;
    color: #fff;
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: 1rem;
    letter-spacing: 0.14em;
    line-height: 1;
    text-transform: uppercase;
    transition:
      background-color 180ms ease,
      border-color 180ms ease;
  }

  .program-card:hover .program-buy {
    border-color: #c9b66b;
    background: #9a893d;
  }

  .program-dialog {
    width: min(100% - 32px, 1040px);
    max-height: min(86vh, 820px);
    border: 0;
    border-radius: 8px;
    padding: 0;
    background: #f1efe6;
    color: #11130f;
    box-shadow: 0 30px 100px rgba(0, 0, 0, 0.48);
  }

  .program-dialog::backdrop {
    background: rgba(7, 8, 7, 0.78);
    backdrop-filter: blur(6px);
  }

  .dialog-shell {
    display: grid;
    grid-template-columns: 0.82fr 1.18fr;
    min-height: 640px;
  }

  .dialog-media {
    position: relative;
    min-height: 420px;
    overflow: hidden;
    background: #070807;
  }

  .dialog-media picture,
  .dialog-media img {
    width: 100%;
    height: 100%;
  }

  .dialog-media img {
    object-fit: cover;
    opacity: 0.88;
  }

  .dialog-media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(7, 8, 7, 0.08), rgba(7, 8, 7, 0.68));
  }

  .dialog-badge {
    position: absolute;
    left: 24px;
    bottom: 24px;
    z-index: 1;
    border-radius: 999px;
    padding: 9px 12px;
    background: #8a7a2f;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .dialog-content {
    position: relative;
    overflow-y: auto;
    padding: 42px;
  }

  .dialog-close {
    position: absolute;
    top: 18px;
    right: 18px;
    display: grid;
    width: 38px;
    height: 38px;
    place-items: center;
    border: 1px solid rgba(17, 19, 15, 0.18);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.42);
    color: #11130f;
    font-size: 1.7rem;
    line-height: 1;
  }

  .dialog-content h3 {
    margin: 14px 48px 0 0;
    font-size: clamp(3rem, 6vw, 5rem);
    text-transform: uppercase;
  }

  .dialog-lead {
    margin: 14px 0 0;
    color: #5d625b;
    font-size: 1.02rem;
    line-height: 1.65;
  }

  .program-meta {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin-top: 28px;
  }

  .program-meta div {
    min-height: 116px;
    border: 1px solid rgba(17, 19, 15, 0.12);
    border-radius: 6px;
    padding: 16px;
    background: rgba(255, 255, 255, 0.38);
  }

  .program-meta svg {
    color: #8a7a2f;
  }

  .program-meta span,
  .program-meta strong {
    display: block;
  }

  .program-meta span {
    margin-top: 12px;
    color: #74786f;
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .program-meta strong {
    margin-top: 5px;
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .dialog-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
    margin-top: 30px;
  }

  .dialog-columns h4 {
    margin: 0 0 12px;
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: 1.6rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .dialog-columns p,
  .dialog-columns li {
    color: #5d625b;
    font-size: 0.94rem;
    line-height: 1.55;
  }

  .dialog-columns ul {
    display: grid;
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .dialog-columns li {
    display: flex;
    align-items: flex-start;
    gap: 9px;
  }

  .dialog-columns li svg {
    flex: 0 0 auto;
    margin-top: 2px;
    color: #8a7a2f;
  }

  .dialog-faq {
    display: grid;
    gap: 8px;
    margin-top: 28px;
  }

  .dialog-faq details {
    border: 1px solid rgba(17, 19, 15, 0.12);
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.32);
  }

  .dialog-faq summary {
    cursor: pointer;
    padding: 14px 16px;
    font-weight: 800;
  }

  .dialog-faq p {
    margin: 0;
    padding: 0 16px 16px;
    color: #62675f;
    font-size: 0.93rem;
    line-height: 1.55;
  }

  .dialog-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 30px;
  }

  @media (max-width: 980px) {
    .program-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 24px;
    }

    .dialog-shell {
      grid-template-columns: 1fr;
    }

    .dialog-media {
      max-height: 360px;
    }
  }

  @media (max-width: 640px) {
    .programs-section {
      padding: 84px 0 88px;
    }

    .section-heading h2 {
      font-size: clamp(3.8rem, 18vw, 5rem);
    }

    .filter-row {
      flex-wrap: wrap;
      justify-content: flex-start;
      overflow: visible;
      margin: 34px 0 18px;
      padding: 0;
    }

    .filter-button {
      flex: 1 1 calc(50% - 6px);
      min-width: 0;
    }

    .program-test-prompt {
      justify-content: flex-start;
      margin-bottom: 34px;
    }

    .program-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .program-card {
      min-height: 456px;
    }

    .program-dialog {
      width: min(100% - 20px, 1040px);
      max-height: 88vh;
    }

    .dialog-content {
      padding: 32px 20px 24px;
    }

    .dialog-close {
      top: 12px;
      right: 12px;
    }

    .program-meta,
    .dialog-columns {
      grid-template-columns: 1fr;
    }

    .dialog-actions .btn {
      width: 100%;
    }
  }
</style>
