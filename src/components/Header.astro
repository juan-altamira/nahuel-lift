---
import { Menu, X } from 'lucide-astro';
import { navItems } from '@/data/site';
---

<header class="site-header" data-header>
  <div class="container-page flex h-full items-center justify-between gap-6">
    <a href="#inicio" class="brand" aria-label="Ir al inicio">NAHUEL LIFTS</a>

    <nav class="hidden items-center gap-10 lg:flex" aria-label="Navegación principal">
      {navItems.map((item) => (
        <a class="nav-link" href={item.href}>{item.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <div class="language-switch" aria-label="Selector de idioma" data-language-switch>
        <button class="language-option is-active" type="button" aria-pressed="true" data-language-button="es">ES</button>
        <button class="language-option" type="button" aria-pressed="false" data-language-button="en">EN</button>
      </div>

      <button class="menu-toggle lg:hidden" type="button" aria-label="Abrir menú" aria-expanded="false" data-menu-toggle>
        <Menu class="menu-icon menu-icon-open" size={22} stroke-width={2.1} aria-hidden="true" />
        <X class="menu-icon menu-icon-close" size={22} stroke-width={2.1} aria-hidden="true" />
      </button>
    </div>
  </div>

  <div class="mobile-panel lg:hidden" data-mobile-panel>
    <nav class="container-page mobile-nav" aria-label="Navegación móvil">
      {navItems.map((item) => (
        <a class="mobile-link" href={item.href} data-mobile-link>{item.label}</a>
      ))}
      <div class="language-switch mobile-language" aria-label="Selector de idioma" data-language-switch>
        <button class="language-option is-active" type="button" aria-pressed="true" data-language-button="es">ES</button>
        <button class="language-option" type="button" aria-pressed="false" data-language-button="en">EN</button>
      </div>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 50;
    height: 76px;
    color: #fff;
    transition:
      background-color 220ms ease,
      border-color 220ms ease,
      color 220ms ease,
      box-shadow 220ms ease;
  }

  .site-header::after {
    content: '';
    position: absolute;
    inset: auto 0 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
    transition: background-color 220ms ease;
  }

  .site-header.is-scrolled {
    background: rgba(241, 239, 230, 0.94);
    color: #11130f;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
    backdrop-filter: blur(14px);
  }

  .site-header.is-scrolled::after {
    background: rgba(17, 19, 15, 0.12);
  }

  .brand {
    position: relative;
    z-index: 2;
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: clamp(1.55rem, 2.1vw, 2rem);
    letter-spacing: 0.11em;
    line-height: 1;
    white-space: nowrap;
  }

  .nav-link {
    position: relative;
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: 1.04rem;
    letter-spacing: 0.12em;
    line-height: 1;
    transition: color 180ms ease, opacity 180ms ease;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -11px;
    height: 1px;
    transform: scaleX(0);
    transform-origin: center;
    background: #a69645;
    transition: transform 180ms ease;
  }

  .nav-link:hover {
    color: #c9b66b;
  }

  .site-header.is-scrolled .nav-link:hover {
    color: #8a7a2f;
  }

  .nav-link:hover::after {
    transform: scaleX(1);
  }

  .language-switch {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    border: 1px solid rgba(255, 255, 255, 0.42);
    border-radius: 999px;
    padding: 4px;
    background: rgba(7, 8, 7, 0.18);
    transition:
      border-color 220ms ease,
      background-color 220ms ease;
  }

  .site-header.is-scrolled .language-switch {
    border-color: rgba(17, 19, 15, 0.18);
    background: rgba(255, 255, 255, 0.5);
  }

  .language-option {
    min-width: 38px;
    height: 34px;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: currentColor;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    transition: background-color 180ms ease, color 180ms ease;
  }

  .language-option.is-active {
    background: #8a7a2f;
    color: #fff;
  }

  .menu-toggle {
    position: relative;
    z-index: 2;
    display: none;
    width: 44px;
    height: 44px;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.32);
    border-radius: 999px;
    background: rgba(7, 8, 7, 0.18);
    color: currentColor;
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      transform 180ms ease;
  }

  .menu-toggle:hover {
    transform: translateY(-1px);
  }

  .site-header.is-scrolled .menu-toggle {
    border-color: rgba(17, 19, 15, 0.18);
    background: rgba(255, 255, 255, 0.5);
  }

  .menu-icon {
    grid-area: 1 / 1;
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .menu-icon-close {
    opacity: 0;
    transform: rotate(-45deg) scale(0.85);
  }

  .site-header.is-open .menu-icon-open {
    opacity: 0;
    transform: rotate(45deg) scale(0.85);
  }

  .site-header.is-open .menu-icon-close {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  .mobile-panel {
    position: fixed;
    top: 76px;
    right: 0;
    bottom: auto;
    left: 0;
    z-index: 1;
    height: calc(100svh - 76px);
    pointer-events: none;
    visibility: hidden;
    background: #070807;
    color: #fff;
    opacity: 0;
    clip-path: circle(0 at calc(100% - 44px) -34px);
    transform: translateY(-8px) scale(0.985);
    transform-origin: top right;
    will-change: clip-path, transform, opacity;
    transition:
      clip-path 680ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity 320ms ease,
      transform 680ms cubic-bezier(0.16, 1, 0.3, 1),
      visibility 680ms ease;
  }

  .site-header.is-open .mobile-panel {
    pointer-events: auto;
    visibility: visible;
    opacity: 1;
    clip-path: circle(150% at calc(100% - 44px) -34px);
    transform: translateY(0) scale(1);
  }

  .mobile-nav {
    display: flex;
    height: 100%;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(24px, 5vh, 38px);
    padding-block: 40px;
    text-align: center;
  }

  .mobile-link {
    font-family: 'Bebas Neue', Impact, sans-serif;
    font-size: clamp(2.65rem, 12vw, 4.6rem);
    letter-spacing: 0.11em;
    line-height: 0.95;
    opacity: 0;
    filter: blur(8px);
    transform: translateY(26px) scale(0.96);
    transition:
      opacity 420ms ease,
      filter 420ms ease,
      transform 520ms cubic-bezier(0.16, 1, 0.3, 1),
      color 180ms ease;
  }

  .mobile-link:hover {
    color: #c9b66b;
  }

  .site-header.is-open .mobile-link {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0) scale(1);
  }

  .site-header.is-open .mobile-link:nth-child(1) {
    transition-delay: 70ms;
  }

  .site-header.is-open .mobile-link:nth-child(2) {
    transition-delay: 120ms;
  }

  .site-header.is-open .mobile-link:nth-child(3) {
    transition-delay: 170ms;
  }

  .site-header.is-open .mobile-link:nth-child(4) {
    transition-delay: 220ms;
  }

  .mobile-language {
    opacity: 0;
    filter: blur(8px);
    transform: translateY(26px) scale(0.96);
    transition:
      opacity 420ms ease,
      filter 420ms ease,
      transform 520ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mobile-language {
    margin-top: 4px;
    border-color: rgba(255, 255, 255, 0.38);
    background: rgba(255, 255, 255, 0.04);
  }

  .site-header.is-open .mobile-language {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0) scale(1);
  }

  .site-header.is-open .mobile-language {
    transition-delay: 270ms;
  }

  @media (min-width: 1024px) {
    .site-header {
      height: 84px;
    }
  }

  @media (max-width: 1023px) {
    .site-header.is-open {
      background: #070807;
      color: #fff;
      box-shadow: none;
      backdrop-filter: none;
    }

    .site-header.is-open::after {
      background: rgba(255, 255, 255, 0.12);
    }

    .site-header.is-open .language-switch {
      border-color: rgba(255, 255, 255, 0.38);
      background: rgba(255, 255, 255, 0.04);
    }

    .site-header.is-open .menu-toggle {
      border-color: rgba(255, 255, 255, 0.28);
      background: transparent;
      transform: rotate(90deg);
    }

    .menu-toggle {
      display: inline-grid;
    }
  }

  @media (max-width: 420px) {
    .language-switch:not(.mobile-language) {
      display: none;
    }

    .brand {
      font-size: 1.42rem;
    }
  }
</style>
