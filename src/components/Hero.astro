---
import { ArrowDown, Mouse } from 'lucide-astro';
import { heroSlides, mentorshipWhatsAppHref } from '@/data/site';
---

<section id="inicio" class="hero" data-hero aria-label="Portada principal">
  <div class="hero-media" aria-hidden="true">
    {heroSlides.map((slide, index) => (
      <div class:list={['hero-slide', { 'is-active': index === 0 }]} data-hero-slide style={`--hero-position:${slide.position}`}>
        <picture>
          <source media="(max-width: 767px)" srcset={slide.mobile.avif} type="image/avif" />
          <source media="(max-width: 767px)" srcset={slide.mobile.webp} type="image/webp" />
          <source srcset={slide.desktop.avif} type="image/avif" />
          <source srcset={slide.desktop.webp} type="image/webp" />
          <img
            src={slide.desktop.webp}
            alt=""
            width="1920"
            height="1080"
            loading={index === 0 ? 'eager' : 'lazy'}
            fetchpriority={index === 0 ? 'high' : 'low'}
            decoding="async"
          />
        </picture>
      </div>
    ))}
  </div>

  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="container-page hero-content">
    <div class="hero-copy">
      <p class="hero-badge" data-reveal>
        <span>+500 atletas ya entrenan con estos programas</span>
      </p>

      <h1 class="display-title hero-title reveal" data-hero-title data-reveal>
        <span data-hero-title-primary>Programas que</span><br />
        <span data-hero-title-secondary>realmente funcionan</span>
      </h1>

      <p class="hero-subtitle reveal" data-reveal>
        Entrená con planes probados, progresivos y claros desde el primer día. Sin improvisar. Sin perder tiempo.
      </p>

      <div class="hero-actions reveal" data-reveal>
        <a class="btn btn-primary" href="#programas">Ver planes</a>
        <a class="btn btn-secondary-dark" href={mentorshipWhatsAppHref} target="_blank" rel="noreferrer">Mentoría 1:1</a>
      </div>

      <p class="hero-microcopy reveal" data-reveal>Acceso digital <span></span> Pago único <span></span> Plan estructurado</p>

      <a class="hero-plan-link reveal" href="#encontra-tu-plan" data-open-quiz data-reveal>
        ¿No sabés cuál elegir? Encontrá tu plan
      </a>

      <div class="hero-dots reveal" role="tablist" aria-label="Imágenes de portada" data-reveal>
        {heroSlides.map((slide, index) => (
          <button
            class:list={['hero-dot', { 'is-active': index === 0 }]}
            type="button"
            aria-label={`Ver imagen ${index + 1}`}
            aria-selected={index === 0 ? 'true' : 'false'}
            role="tab"
            data-hero-dot
            data-slide-index={index}
          >
            <span></span>
          </button>
        ))}
      </div>
    </div>
  </div>

  <a class="hero-scroll" href="#programas" aria-label="Ir a programas">
    <span>Ver planes</span>
    <Mouse size={28} stroke-width={1.5} aria-hidden="true" />
    <ArrowDown class="hero-scroll-arrow" size={14} stroke-width={1.8} aria-hidden="true" />
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    background: #070807;
    color: #fff;
    isolation: isolate;
  }

  .hero-media,
  .hero-slide,
  .hero-slide picture,
  .hero-slide img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-slide {
    opacity: 0;
    transition: opacity 900ms ease;
    will-change: opacity;
  }

  .hero-slide.is-active {
    opacity: 1;
  }

  .hero-slide img {
    object-fit: cover;
    object-position: var(--hero-position, 50% 50%);
    transform: scale(1);
    transition: transform 5200ms ease-out;
  }

  .hero-slide.is-active img {
    transform: scale(1.045);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg, rgba(7, 8, 7, 0.78) 0%, rgba(7, 8, 7, 0.18) 24%, rgba(7, 8, 7, 0.68) 100%),
      radial-gradient(circle at center, rgba(7, 8, 7, 0.16) 0%, rgba(7, 8, 7, 0.34) 38%, rgba(7, 8, 7, 0.82) 100%),
      linear-gradient(90deg, rgba(7, 8, 7, 0.68) 0%, rgba(7, 8, 7, 0.18) 38%, rgba(7, 8, 7, 0.72) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    display: grid;
    min-height: 100svh;
    place-items: center;
    padding-block: 116px 120px;
  }

  .hero-copy {
    width: min(100%, 1080px);
    margin-top: 18px;
    text-align: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 30px;
    margin: 0 0 22px;
    border: 1px solid rgba(201, 182, 107, 0.32);
    border-radius: 999px;
    padding: 6px 14px;
    background: rgba(49, 45, 20, 0.62);
    color: rgba(255, 255, 255, 0.88);
    font-size: clamp(0.68rem, 1.3vw, 0.78rem);
    font-weight: 800;
    letter-spacing: 0.13em;
    line-height: 1.2;
    text-transform: uppercase;
    backdrop-filter: blur(10px);
  }

  .hero-badge::before {
    content: '🔥';
    margin-right: 8px;
    font-size: 0.95rem;
  }

  .hero-title {
    margin: 0;
    font-size: clamp(4.2rem, 8.4vw, 7.7rem);
    text-transform: uppercase;
    text-shadow: 0 24px 70px rgba(0, 0, 0, 0.42);
  }

  .hero-subtitle {
    width: min(100%, 620px);
    margin: 22px auto 0;
    color: rgba(255, 255, 255, 0.78);
    font-size: clamp(1rem, 1.6vw, 1.18rem);
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
    margin-top: 34px;
  }

  .hero-actions .btn {
    min-width: 184px;
  }

  .hero-microcopy {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 13px;
    margin: 24px 0 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.84rem;
    font-weight: 600;
  }

  .hero-microcopy span {
    width: 4px;
    height: 4px;
    border-radius: 999px;
    background: rgba(201, 182, 107, 0.68);
  }

  .hero-plan-link {
    display: inline-flex;
    margin-top: 18px;
    color: rgba(255, 255, 255, 0.64);
    font-size: 0.86rem;
    font-weight: 750;
    transition: color 180ms ease;
  }

  .hero-plan-link:hover {
    color: #c9b66b;
  }

  .hero-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 30px;
  }

  .hero-dot {
    display: grid;
    width: 28px;
    height: 18px;
    place-items: center;
    border: 0;
    background: transparent;
  }

  .hero-dot span {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.34);
    transition:
      width 220ms ease,
      background-color 220ms ease;
  }

  .hero-dot.is-active span {
    width: 28px;
    background: #fff;
  }

  .hero-scroll {
    position: absolute;
    left: 50%;
    bottom: 22px;
    z-index: 3;
    display: none;
    transform: translateX(-50%);
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: rgba(255, 255, 255, 0.74);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .hero-scroll svg {
    opacity: 0.82;
  }

  .hero-scroll-arrow {
    margin-top: -22px;
    animation: scrollPulse 1500ms ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%,
    100% {
      transform: translateY(0);
      opacity: 0.45;
    }

    50% {
      transform: translateY(5px);
      opacity: 1;
    }
  }

  @media (min-width: 768px) {
    .hero-scroll {
      display: flex;
    }
  }

  @media (max-width: 640px) {
    .hero {
      min-height: 94svh;
    }

    .hero-content {
      min-height: 94svh;
      padding-block: 112px 66px;
    }

    .hero-slide.is-active img {
      transform: scale(1);
    }

    .hero-copy {
      margin-top: 0;
    }

    .hero-title {
      font-size: clamp(4rem, 19vw, 5.8rem);
      line-height: 0.91;
    }

    .hero-subtitle {
      margin-top: 22px;
      font-size: 1rem;
      line-height: 1.55;
    }

    .hero-actions {
      display: grid;
      gap: 12px;
      margin-top: 32px;
    }

    .hero-actions .btn {
      width: min(100%, 340px);
      margin-inline: auto;
    }

    .hero-microcopy {
      max-width: 280px;
      margin-inline: auto;
      line-height: 1.6;
    }

    .hero-dots {
      margin-top: 34px;
    }
  }
</style>
