---
import { ArrowRight, RotateCcw } from 'lucide-astro';
---

<section id="encontra-tu-plan" class="plan-finder-section">
  <div class="container-page plan-finder-panel reveal" data-reveal>
    <div class="plan-finder-copy">
      <h2 class="display-title">¿NO SABES QUE PLAN ELEGIR?</h2>
      <div class="plan-finder-arrow" aria-hidden="true">
        <span></span>
        <ArrowRight size={54} stroke-width={1.35} />
      </div>
    </div>

    <section class="quiz-card" data-plan-quiz tabindex="-1" aria-label="Encontrá tu plan">
      <header class="quiz-header">
        <div>
          <p class="section-kicker">Test de recomendación</p>
          <h3 class="display-title">Encontrá tu plan</h3>
        </div>
        <span data-quiz-progress-label>Paso 1/6</span>
      </header>

      <div
        class="quiz-progress-bar"
        role="progressbar"
        aria-label="Avance del test"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow="17"
        data-quiz-progress
      >
        <span data-quiz-progress-bar></span>
      </div>
      <p class="quiz-progress-percent" data-quiz-progress-percent>17%</p>

      <div class="quiz-step-panel" data-quiz-step-panel>
        <p class="quiz-error" data-quiz-error hidden>Elegí una opción para continuar.</p>
        <h4 data-quiz-question>¿Qué querés mejorar primero?</h4>
        <div class="quiz-options" data-quiz-options></div>
      </div>

      <div class="quiz-result" data-quiz-result hidden>
        <p class="quiz-result-kicker">TU PLAN RECOMENDADO</p>
        <h4 class="display-title" data-result-title>PLAN HÍBRIDO</h4>
        <p data-result-description>
          Ideal para vos si querés un físico atlético y completo, combinando fuerza, resistencia y variedad sin
          enfocarte en una sola cosa.
        </p>

        <div class="quiz-reason">
          <h5>Por qué te lo recomendamos:</h5>
          <p data-result-reason>
            Tus respuestas muestran que no buscás solo músculo ni solo resistencia: querés verte mejor, sentirte más
            capaz y entrenar de forma más completa.
          </p>
        </div>
      </div>

      <div class="quiz-actions">
        <button class="btn quiz-back" type="button" data-quiz-back>Atrás</button>
        <button class="btn btn-primary quiz-next" type="button" data-quiz-next>Siguiente</button>
        <button class="btn btn-primary quiz-result-cta" type="button" data-quiz-result-cta hidden>
          VER PLAN HÍBRIDO
          <ArrowRight size={17} stroke-width={2} aria-hidden="true" />
        </button>
        <button class="btn btn-secondary-dark quiz-restart" type="button" data-quiz-restart hidden>
          <RotateCcw size={16} stroke-width={2} aria-hidden="true" />
          Rehacer test
        </button>
      </div>
    </section>
  </div>
</section>

<style>
  .plan-finder-section {
    background: #f1efe6;
    color: #11130f;
    padding: 0 0 116px;
    scroll-margin-top: 96px;
  }

  .plan-finder-panel {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(420px, 1fr);
    gap: clamp(34px, 5vw, 78px);
    align-items: center;
    overflow: hidden;
    border-radius: 8px;
    padding: clamp(34px, 6vw, 66px);
    background:
      radial-gradient(circle at 14% 18%, rgba(138, 122, 47, 0.22), transparent 36%),
      linear-gradient(135deg, rgba(166, 150, 69, 0.12), transparent 42%),
      #070807;
    color: #fff;
    box-shadow: 0 28px 70px rgba(17, 19, 15, 0.18);
  }

  .plan-finder-copy {
    display: grid;
    align-content: center;
    gap: clamp(26px, 4vw, 42px);
  }

  .plan-finder-copy h2 {
    max-width: 520px;
    margin: 0;
    color: #f1efe6;
    font-size: clamp(4rem, 7.2vw, 7rem);
    text-transform: uppercase;
  }

  .plan-finder-arrow {
    display: flex;
    width: min(100%, 360px);
    align-items: center;
    gap: 16px;
    color: #c9b66b;
  }

  .plan-finder-arrow span {
    height: 1px;
    flex: 1 1 auto;
    background: linear-gradient(90deg, transparent, rgba(201, 182, 107, 0.9));
  }

  .plan-finder-arrow svg {
    flex: 0 0 auto;
    filter: drop-shadow(0 0 18px rgba(201, 182, 107, 0.28));
  }

  .quiz-card {
    border: 1px solid rgba(255, 255, 255, 0.13);
    border-radius: 8px;
    padding: clamp(24px, 4vw, 38px);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.025)),
      #11130f;
    box-shadow: 0 24px 62px rgba(0, 0, 0, 0.28);
  }

  .quiz-card:focus-visible {
    outline: 2px solid #c9b66b;
    outline-offset: 5px;
  }

  .quiz-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 22px;
  }

  .quiz-header .section-kicker::before {
    width: 18px;
  }

  .quiz-header h3 {
    margin: 12px 0 0;
    color: #fff;
    font-size: clamp(3.2rem, 5.8vw, 4.8rem);
    text-transform: uppercase;
  }

  .quiz-header > span,
  .quiz-progress-percent {
    color: rgba(255, 255, 255, 0.58);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .quiz-progress-bar {
    height: 13px;
    margin-top: 28px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.11);
  }

  .quiz-progress-bar span {
    display: block;
    width: 17%;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #8a7a2f, #c9b66b);
    box-shadow: 0 0 24px rgba(201, 182, 107, 0.36);
    transition: width 260ms ease;
  }

  .quiz-progress-percent {
    margin: 10px 0 0;
    text-align: right;
  }

  .quiz-step-panel,
  .quiz-result {
    margin-top: 28px;
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .quiz-step-panel.is-switching,
  .quiz-result.is-switching {
    opacity: 0;
    transform: translateY(8px);
  }

  .quiz-error {
    margin: 0 0 14px;
    color: #c9b66b;
    font-size: 0.9rem;
    font-weight: 850;
  }

  .quiz-step-panel h4 {
    margin: 0;
    color: #fff;
    font-size: clamp(1.28rem, 3vw, 1.65rem);
    font-weight: 850;
    line-height: 1.3;
  }

  .quiz-options {
    display: grid;
    gap: 12px;
    margin-top: 22px;
  }

  :global(.quiz-option) {
    position: relative;
    display: flex;
    width: 100%;
    min-height: 58px;
    align-items: center;
    justify-content: flex-start;
    gap: 14px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 8px;
    padding: 15px 18px;
    background: rgba(7, 8, 7, 0.44);
    color: rgba(255, 255, 255, 0.8);
    text-align: left;
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  :global(.quiz-option span) {
    flex: 1 1 auto;
    text-align: left;
  }

  :global(.quiz-option:hover) {
    border-color: #a69645;
    background: rgba(49, 45, 20, 0.58);
    color: #fff;
    transform: translateY(-1px);
  }

  :global(.quiz-option)::before {
    content: '';
    flex: 0 0 auto;
    width: 16px;
    height: 16px;
    border: 1px solid rgba(255, 255, 255, 0.34);
    border-radius: 999px;
    transition:
      border-color 180ms ease,
      background 180ms ease;
  }

  :global(.quiz-option.is-selected) {
    border-color: #c9b66b;
    background:
      linear-gradient(90deg, rgba(201, 182, 107, 0.2), transparent 58%),
      rgba(49, 45, 20, 0.92);
    color: #fff;
    box-shadow:
      inset 0 0 0 1px rgba(201, 182, 107, 0.42),
      0 14px 30px rgba(0, 0, 0, 0.18);
    transform: translateY(-1px);
  }

  :global(.quiz-option.is-selected)::before {
    border-color: #c9b66b;
    background: radial-gradient(circle, #fff 0 26%, #8a7a2f 30% 100%);
  }

  .quiz-result {
    border: 1px solid rgba(201, 182, 107, 0.28);
    border-radius: 8px;
    padding: clamp(22px, 4vw, 30px);
    background:
      linear-gradient(135deg, rgba(138, 122, 47, 0.2), transparent 46%),
      rgba(7, 8, 7, 0.4);
  }

  .quiz-result-kicker {
    margin: 0;
    color: #c9b66b;
    font-size: 0.8rem;
    font-weight: 950;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .quiz-result h4 {
    margin: 12px 0 0;
    color: #fff;
    font-size: clamp(3rem, 6vw, 4.8rem);
    text-transform: uppercase;
  }

  .quiz-result > p:not(.quiz-result-kicker) {
    margin: 16px 0 0;
    color: rgba(255, 255, 255, 0.74);
    font-size: 1rem;
    line-height: 1.68;
  }

  .quiz-reason {
    margin-top: 22px;
    border-left: 4px solid #c9b66b;
    padding-left: 16px;
  }

  .quiz-reason h5 {
    margin: 0;
    color: #fff;
    font-size: 0.82rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .quiz-reason p {
    margin: 9px 0 0;
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.94rem;
    line-height: 1.58;
  }

  .quiz-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .quiz-back {
    min-width: 128px;
    border-color: rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.04);
    color: #fff;
  }

  .quiz-back:hover {
    border-color: #a69645;
    color: #c9b66b;
  }

  .quiz-next,
  .quiz-result-cta {
    flex: 1 1 220px;
  }

  .quiz-restart {
    flex: 0 1 auto;
  }

  @media (max-width: 920px) {
    .plan-finder-panel {
      grid-template-columns: 1fr;
    }

    .plan-finder-copy {
      gap: 22px;
    }

    .plan-finder-copy h2 {
      max-width: 720px;
    }

    .plan-finder-arrow {
      width: 82px;
      height: 96px;
      flex-direction: column;
      align-items: center;
      justify-self: start;
      gap: 10px;
      margin-left: 36px;
    }

    .plan-finder-arrow span {
      width: 1px;
      height: 68px;
      flex: 0 0 68px;
      background: linear-gradient(180deg, rgba(201, 182, 107, 0.9), transparent);
    }

    .plan-finder-arrow svg {
      transform: rotate(90deg);
    }
  }

  @media (max-width: 640px) {
    .plan-finder-section {
      padding-bottom: 86px;
    }

    .plan-finder-panel {
      padding: 30px 20px;
    }

    .plan-finder-copy h2 {
      font-size: clamp(3.6rem, 17vw, 5.3rem);
    }

    .quiz-card {
      padding: 22px 18px;
    }

    .quiz-header {
      display: grid;
      gap: 12px;
    }

    .quiz-header h3 {
      font-size: clamp(3rem, 15vw, 4.3rem);
    }

    .quiz-actions {
      display: grid;
    }

    .quiz-actions .btn {
      width: 100%;
    }

    :global(.quiz-option) {
      align-items: flex-start;
    }

    .quiz-result h4 {
      font-size: clamp(2.7rem, 15vw, 4.2rem);
    }
  }
</style>
