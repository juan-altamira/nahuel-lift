---
import { RefreshCw } from 'lucide-astro';
import '../styles/global.css';

const pageTitle = 'Visitas | Nahuel Lifts';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#f1efe6" />
    <link rel="icon" href="/favicon.png" type="image/png" />
  </head>
  <body class="visits-screen">
    <main class="visits-shell" aria-live="polite">
      <header class="visits-topbar">
        <div>
          <p class="visits-kicker">Vercel Analytics</p>
          <h1>Visitas</h1>
        </div>

        <div class="visits-actions" aria-label="Periodo">
          <div class="period-control">
            <button class="period-button" type="button" data-period="7">7d</button>
            <button class="period-button is-active" type="button" data-period="30">30d</button>
            <button class="period-button" type="button" data-period="90">90d</button>
            <button class="period-button" type="button" data-period="all">Todo</button>
          </div>

          <button class="icon-button" type="button" id="refreshButton" aria-label="Actualizar">
            <RefreshCw size={18} stroke-width={2.25} />
          </button>
        </div>
      </header>

      <section class="hero-metric" aria-label="Resumen de visitas">
        <div>
          <p class="metric-label">Total</p>
          <p class="metric-number" id="visitsTotal">0</p>
        </div>

        <div class="metric-stack">
          <div>
            <p class="stack-value" id="visitorsTotal">0</p>
            <p class="stack-label">Visitantes</p>
          </div>
          <div>
            <p class="stack-value" id="sessionsTotal">0</p>
            <p class="stack-label">Sesiones</p>
          </div>
          <div>
            <p class="stack-value stack-time" id="updatedAt">Sin datos</p>
            <p class="stack-label">Actualizado</p>
          </div>
        </div>
      </section>

      <section class="trend-panel" aria-label="Tendencia de visitas">
        <canvas id="trendCanvas" width="1100" height="220"></canvas>
      </section>

      <section class="visits-grid">
        <article class="panel countries-panel">
          <div class="panel-heading">
            <h2>De dónde son</h2>
            <p id="countriesCount">0 paises</p>
          </div>
          <div class="bars-list" id="countriesList"></div>
        </article>

        <article class="panel">
          <div class="panel-heading">
            <h2>Ciudades</h2>
            <p>Top</p>
          </div>
          <div class="compact-list" id="citiesList"></div>
        </article>

        <article class="panel">
          <div class="panel-heading">
            <h2>Páginas</h2>
            <p>Entradas</p>
          </div>
          <div class="compact-list" id="pathsList"></div>
        </article>
      </section>

      <p class="status-line" id="statusLine">Cargando datos</p>
    </main>

    <script is:inline>
      const state = {
        period: new URLSearchParams(window.location.search).get('period') || '30',
        key: new URLSearchParams(window.location.search).get('key') || ''
      };

      const numberFormatter = new Intl.NumberFormat('es-AR');
      const percentFormatter = new Intl.NumberFormat('es-AR', {
        maximumFractionDigits: 1,
        minimumFractionDigits: 0
      });

      const elements = {
        visitsTotal: document.getElementById('visitsTotal'),
        visitorsTotal: document.getElementById('visitorsTotal'),
        sessionsTotal: document.getElementById('sessionsTotal'),
        updatedAt: document.getElementById('updatedAt'),
        countriesCount: document.getElementById('countriesCount'),
        countriesList: document.getElementById('countriesList'),
        citiesList: document.getElementById('citiesList'),
        pathsList: document.getElementById('pathsList'),
        statusLine: document.getElementById('statusLine'),
        refreshButton: document.getElementById('refreshButton'),
        trendCanvas: document.getElementById('trendCanvas')
      };

      const periodButtons = [...document.querySelectorAll('[data-period]')];

      periodButtons.forEach((button) => {
        button.classList.toggle('is-active', button.dataset.period === state.period);
        button.addEventListener('click', () => {
          state.period = button.dataset.period;
          periodButtons.forEach((item) => item.classList.toggle('is-active', item === button));
          loadAnalytics();
        });
      });

      elements.refreshButton.addEventListener('click', () => {
        loadAnalytics();
      });

      window.addEventListener('resize', () => {
        if (window.__latestTrend) {
          drawTrend(window.__latestTrend);
        }
      });

      async function loadAnalytics() {
        setStatus('Cargando datos');
        elements.refreshButton.classList.add('is-loading');

        try {
          const url = new URL('/api/analytics/summary.json', window.location.origin);
          url.searchParams.set('period', state.period);

          if (state.key) {
            url.searchParams.set('key', state.key);
          }

          const response = await fetch(url, {
            headers: state.key ? { 'x-dashboard-token': state.key } : {},
            cache: 'no-store'
          });

          const data = await response.json();

          if (!response.ok) {
            throw new Error(data.error || 'No se pudieron leer las visitas');
          }

          render(data);
        } catch (error) {
          renderEmpty();
          setStatus(error instanceof Error ? error.message : 'No se pudieron leer las visitas');
        } finally {
          elements.refreshButton.classList.remove('is-loading');
        }
      }

      function render(data) {
        elements.visitsTotal.textContent = formatNumber(data.totals.visits);
        elements.visitorsTotal.textContent = formatNumber(data.totals.visitors);
        elements.sessionsTotal.textContent = formatNumber(data.totals.sessions);
        elements.updatedAt.textContent = data.updatedAt ? formatTime(data.updatedAt) : 'Sin eventos';
        elements.countriesCount.textContent = `${data.countries.length} ${data.countries.length === 1 ? 'pais' : 'paises'}`;

        renderCountries(data.countries);
        renderCompactList(elements.citiesList, data.cities, 'label');
        renderCompactList(elements.pathsList, data.paths, 'path');

        window.__latestTrend = data.trend;
        drawTrend(data.trend);

        if (!data.storage?.configured) {
          setStatus('Storage sin configurar');
          return;
        }

        setStatus(data.source.hasData ? 'Datos actualizados' : 'Esperando eventos');
      }

      function renderEmpty() {
        elements.visitsTotal.textContent = '0';
        elements.visitorsTotal.textContent = '0';
        elements.sessionsTotal.textContent = '0';
        elements.updatedAt.textContent = 'Sin datos';
        elements.countriesCount.textContent = '0 paises';
        elements.countriesList.innerHTML = emptyRow('Sin ubicaciones');
        elements.citiesList.innerHTML = emptyRow('Sin ciudades');
        elements.pathsList.innerHTML = emptyRow('Sin paginas');
        drawTrend([]);
      }

      function renderCountries(countries) {
        if (!countries.length) {
          elements.countriesList.innerHTML = emptyRow('Sin ubicaciones');
          return;
        }

        elements.countriesList.innerHTML = countries
          .map((country) => {
            const share = clampPercent(country.share);

            return `
              <div class="bar-row">
                <div class="bar-copy">
                  <span>${escapeHtml(country.name)}</span>
                  <strong>${formatNumber(country.visits)}</strong>
                </div>
                <div class="bar-track" aria-hidden="true">
                  <span style="width:${share}%"></span>
                </div>
                <p>${percentFormatter.format(country.share)}%</p>
              </div>
            `;
          })
          .join('');
      }

      function renderCompactList(target, items, labelKey) {
        if (!items.length) {
          target.innerHTML = emptyRow(labelKey === 'path' ? 'Sin paginas' : 'Sin ciudades');
          return;
        }

        target.innerHTML = items
          .map((item) => {
            const share = clampPercent(item.share);

            return `
              <div class="compact-row">
                <span>${escapeHtml(item[labelKey])}</span>
                <strong>${formatNumber(item.visits)}</strong>
                <i style="width:${share}%" aria-hidden="true"></i>
              </div>
            `;
          })
          .join('');
      }

      function drawTrend(trend) {
        const canvas = elements.trendCanvas;
        const context = canvas.getContext('2d');
        const rect = canvas.getBoundingClientRect();
        const ratio = window.devicePixelRatio || 1;
        const width = Math.max(1, Math.floor(rect.width * ratio));
        const height = Math.max(1, Math.floor(rect.height * ratio));
        canvas.width = width;
        canvas.height = height;
        context.scale(ratio, ratio);
        context.clearRect(0, 0, rect.width, rect.height);

        const points = trend && trend.length ? trend : Array.from({ length: 8 }, (_, index) => ({
          date: String(index),
          visits: 0,
          visitors: 0
        }));
        const max = Math.max(1, ...points.map((point) => point.visits));
        const padding = 20;
        const graphWidth = rect.width - padding * 2;
        const graphHeight = rect.height - padding * 2;

        context.lineWidth = 2;
        context.strokeStyle = 'rgba(17, 19, 15, 0.11)';

        for (let index = 0; index < 4; index += 1) {
          const y = padding + (graphHeight / 3) * index;
          context.beginPath();
          context.moveTo(padding, y);
          context.lineTo(rect.width - padding, y);
          context.stroke();
        }

        context.lineWidth = 4;
        context.strokeStyle = '#8a7a2f';
        context.lineJoin = 'round';
        context.lineCap = 'round';
        context.beginPath();

        points.forEach((point, index) => {
          const x = points.length === 1 ? rect.width / 2 : padding + (graphWidth / Math.max(1, points.length - 1)) * index;
          const y = padding + graphHeight - (point.visits / max) * graphHeight;

          if (index === 0) {
            context.moveTo(x, y);
          } else {
            context.lineTo(x, y);
          }
        });

        context.stroke();

        context.fillStyle = '#11130f';
        points.forEach((point, index) => {
          const x = points.length === 1 ? rect.width / 2 : padding + (graphWidth / Math.max(1, points.length - 1)) * index;
          const y = padding + graphHeight - (point.visits / max) * graphHeight;
          context.beginPath();
          context.arc(x, y, 4, 0, Math.PI * 2);
          context.fill();
        });
      }

      function setStatus(message) {
        elements.statusLine.textContent = message;
      }

      function emptyRow(label) {
        return `<p class="empty-row">${label}</p>`;
      }

      function formatNumber(value) {
        return numberFormatter.format(value || 0);
      }

      function formatTime(value) {
        return new Intl.DateTimeFormat('es-AR', {
          hour: '2-digit',
          minute: '2-digit',
          hour12: false,
          day: '2-digit',
          month: 'short'
        })
          .format(new Date(value))
          .replace('.', '');
      }

      function clampPercent(value) {
        return Math.max(4, Math.min(100, Number(value) || 0));
      }

      function escapeHtml(value) {
        return String(value)
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#039;');
      }

      loadAnalytics();
      window.setInterval(loadAnalytics, 60000);
    </script>

    <style>
      :global(body.visits-screen) {
        min-height: 100vh;
        background:
          linear-gradient(180deg, rgba(251, 250, 244, 0.96), rgba(241, 239, 230, 0.96)),
          #f1efe6;
        color: #11130f;
      }

      .visits-shell {
        display: grid;
        min-height: 100vh;
        width: min(100% - 32px, 1380px);
        margin-inline: auto;
        padding: 28px 0;
        gap: 22px;
      }

      .visits-topbar,
      .hero-metric,
      .visits-grid,
      .panel-heading,
      .bar-copy,
      .compact-row {
        display: flex;
        align-items: center;
      }

      .visits-topbar {
        justify-content: space-between;
        gap: 18px;
      }

      .visits-kicker,
      .metric-label,
      .stack-label,
      .panel-heading p,
      .status-line,
      .bar-row p {
        margin: 0;
        color: rgba(17, 19, 15, 0.62);
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.11em;
        text-transform: uppercase;
      }

      h1,
      h2,
      .metric-number,
      .stack-value {
        margin: 0;
        font-family: 'Bebas Neue', Impact, sans-serif;
        letter-spacing: 0.03em;
      }

      h1 {
        font-size: 3.6rem;
        line-height: 0.92;
      }

      h2 {
        font-size: 2rem;
        line-height: 1;
      }

      .visits-actions {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .period-control {
        display: inline-grid;
        grid-template-columns: repeat(4, minmax(58px, 1fr));
        min-height: 46px;
        overflow: hidden;
        border: 1px solid rgba(17, 19, 15, 0.16);
        border-radius: 8px;
        background: rgba(251, 250, 244, 0.72);
      }

      .period-button,
      .icon-button {
        border: 0;
        background: transparent;
        color: #11130f;
      }

      .period-button {
        min-height: 46px;
        padding: 0 14px;
        font-size: 0.82rem;
        font-weight: 900;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .period-button.is-active {
        background: #11130f;
        color: #fbfaf4;
      }

      .icon-button {
        display: inline-grid;
        width: 46px;
        height: 46px;
        place-items: center;
        border: 1px solid rgba(17, 19, 15, 0.16);
        border-radius: 8px;
        background: rgba(251, 250, 244, 0.72);
      }

      .icon-button.is-loading svg {
        animation: spin 900ms linear infinite;
      }

      .hero-metric {
        justify-content: space-between;
        gap: 32px;
        padding: 34px 0 18px;
        border-top: 1px solid rgba(17, 19, 15, 0.12);
      }

      .metric-number {
        min-height: 0.95em;
        font-size: 10.5rem;
        line-height: 0.82;
      }

      .metric-stack {
        display: grid;
        width: min(100%, 420px);
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
      }

      .metric-stack > div {
        min-height: 118px;
        display: grid;
        align-content: center;
        gap: 8px;
        border-left: 1px solid rgba(17, 19, 15, 0.12);
        padding-left: 18px;
      }

      .stack-value {
        font-size: 2.7rem;
        line-height: 0.9;
      }

      .stack-time {
        font-family: 'Inter Variable', Inter, system-ui, sans-serif;
        font-size: 1rem;
        font-weight: 900;
        letter-spacing: 0.04em;
        line-height: 1.25;
        text-transform: uppercase;
      }

      .trend-panel {
        min-height: 240px;
        border-block: 1px solid rgba(17, 19, 15, 0.12);
        padding: 18px 0;
      }

      #trendCanvas {
        display: block;
        width: 100%;
        height: 220px;
      }

      .visits-grid {
        align-items: stretch;
        display: grid;
        grid-template-columns: 1.4fr 1fr 1fr;
        gap: 18px;
      }

      .panel {
        display: grid;
        align-content: start;
        gap: 20px;
        min-height: 280px;
        border: 1px solid rgba(17, 19, 15, 0.12);
        border-radius: 8px;
        background: rgba(251, 250, 244, 0.68);
        padding: 22px;
      }

      .panel-heading {
        justify-content: space-between;
        gap: 18px;
      }

      .bars-list,
      .compact-list {
        display: grid;
        gap: 15px;
      }

      .bar-row {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 8px 16px;
      }

      .bar-copy {
        justify-content: space-between;
        gap: 16px;
        grid-column: 1 / -1;
      }

      .bar-copy span,
      .compact-row span {
        min-width: 0;
        overflow: hidden;
        color: #11130f;
        font-size: 1rem;
        font-weight: 800;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .bar-copy strong,
      .compact-row strong {
        font-size: 1rem;
        font-weight: 900;
      }

      .bar-track {
        height: 10px;
        overflow: hidden;
        border-radius: 999px;
        background: rgba(17, 19, 15, 0.1);
      }

      .bar-track span {
        display: block;
        height: 100%;
        border-radius: inherit;
        background: #8a7a2f;
      }

      .compact-row {
        position: relative;
        min-height: 42px;
        justify-content: space-between;
        gap: 18px;
        overflow: hidden;
        border-bottom: 1px solid rgba(17, 19, 15, 0.1);
        padding: 0 0 12px;
      }

      .compact-row i {
        position: absolute;
        right: 0;
        bottom: -1px;
        left: auto;
        height: 2px;
        background: #8a7a2f;
      }

      .empty-row {
        margin: 0;
        color: rgba(17, 19, 15, 0.58);
        font-weight: 800;
      }

      .status-line {
        justify-self: end;
        padding-bottom: 2px;
      }

      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }

      @media (max-width: 1024px) {
        .hero-metric {
          align-items: flex-start;
          flex-direction: column;
        }

        .metric-stack {
          width: 100%;
        }

        .visits-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 720px) {
        .visits-shell {
          width: min(100% - 24px, 1380px);
          padding: 20px 0;
        }

        .visits-topbar,
        .visits-actions {
          align-items: stretch;
          flex-direction: column;
        }

        .period-control {
          width: 100%;
        }

        .icon-button {
          width: 100%;
        }

        h1 {
          font-size: 3rem;
        }

        .metric-number {
          font-size: 6.5rem;
        }

        .metric-stack {
          grid-template-columns: 1fr;
        }

        .metric-stack > div {
          min-height: 80px;
          border-left: 0;
          border-top: 1px solid rgba(17, 19, 15, 0.12);
          padding: 14px 0 0;
        }

        .trend-panel {
          min-height: 180px;
        }

        #trendCanvas {
          height: 170px;
        }

        .panel {
          padding: 18px;
        }
      }
    </style>
  </body>
</html>
