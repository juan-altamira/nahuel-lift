---
import '../styles/global.css';

type Props = {
  title?: string;
  description?: string;
};

const {
  title = 'Nahuel Lifts | Programas de entrenamiento',
  description = 'Programas estructurados para fuerza, running, hipertrofia y rendimiento híbrido.'
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#070807" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="preload" as="image" href="/assets/images/hero-slider-1-desktop.avif" media="(min-width: 768px)" fetchpriority="high" />
    <link rel="preload" as="image" href="/assets/images/hero-slider-1-mobile.avif" media="(max-width: 767px)" fetchpriority="high" />
  </head>
  <body>
    <slot />
  </body>
</html>
