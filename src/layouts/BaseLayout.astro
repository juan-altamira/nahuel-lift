---
import Analytics from '@vercel/analytics/astro';
import '../styles/global.css';

type Props = {
  title?: string;
  description?: string;
};

const {
  title = 'Nahuel Lifts | Programas de entrenamiento',
  description = 'Programas estructurados para fuerza, running, hipertrofia y rendimiento híbrido.'
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#070807" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="preload" as="image" href="/assets/images/hero-slider-1-desktop.avif" media="(min-width: 768px)" fetchpriority="high" />
    <link rel="preload" as="image" href="/assets/images/hero-slider-1-mobile.avif" media="(max-width: 767px)" fetchpriority="high" />
    <Analytics />
  </head>
  <body>
    <slot />
    <script is:inline>
      (() => {
        const path = window.location.pathname;

        if (path.startsWith('/visitas') || path.startsWith('/api/')) return;

        const getId = (key) => {
          try {
            const storage = key === 'nahuel_visitor_id' ? window.localStorage : window.sessionStorage;
            const current = storage.getItem(key);

            if (current) return current;

            const next =
              window.crypto && 'randomUUID' in window.crypto
                ? window.crypto.randomUUID()
                : `${Date.now()}-${Math.random().toString(16).slice(2)}`;
            storage.setItem(key, next);
            return next;
          } catch {
            return `${Date.now()}-${Math.random().toString(16).slice(2)}`;
          }
        };

        window.addEventListener(
          'load',
          () => {
            fetch('/api/visitas/summary.json', {
              method: 'POST',
              headers: {
                'content-type': 'application/json',
                'x-nahuel-analytics': 'pageview'
              },
              body: JSON.stringify({
                path,
                referrer: document.referrer,
                deviceId: getId('nahuel_visitor_id'),
                sessionId: getId('nahuel_session_id')
              }),
              keepalive: true
            }).catch(() => {});
          },
          { once: true }
        );
      })();
    </script>
  </body>
</html>
